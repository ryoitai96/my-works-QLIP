generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

/// ユーザーアカウント（全ロール共通）
model User {
  id        String   @id @default(uuid())
  email     String   @unique
  name      String
  role      String   // R01-R07
  siteId    String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("users")
}
