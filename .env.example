# Database
# PgBouncer経由（ポート6543）: アプリランタイム用
DATABASE_URL="postgresql://postgres:postgres@localhost:6543/qlip_dev?pgbouncer=true&connection_limit=1"
# ダイレクト接続（ポート5432）: Prismaマイグレーション用
DIRECT_URL="postgresql://postgres:postgres@localhost:5432/qlip_dev"

# Application
NODE_ENV=development
API_PORT=3001
WEB_PORT=3000

# Auth (Phase 0: basic session)
JWT_SECRET=change-me-in-production
